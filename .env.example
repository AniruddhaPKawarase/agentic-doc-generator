# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_INPUT_COST_PER_MILLION=0.40
OPENAI_OUTPUT_COST_PER_MILLION=1.60

# Data Source API
API_BASE_URL=https://your-api-base-url.com
SUMMARY_BY_TRADE_PATH=/api/drawingText/summaryByTrade
API_AUTH_TOKEN=your-api-auth-token
API_TIMEOUT_SECONDS=30
API_PAGE_SIZE=500
MAX_PAGINATION_PAGES=200
MAX_SUMMARY_RECORDS=0

# Server Configuration
APP_HOST=0.0.0.0
APP_PORT=8003
APP_ENV=development

# LLM Context Settings
MAX_CONTEXT_TOKENS=120000
MAX_OUTPUT_TOKENS=3000
INTENT_MAX_TOKENS=500
FOLLOW_UP_MAX_TOKENS=500
FOLLOW_UP_QUESTIONS_COUNT=3

# Cache (Redis optional)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SUMMARY_DATA=86400
CACHE_TTL_QUERY=3600

# Session Management
SESSION_MAX_MESSAGES=50
SESSION_TTL=86400

# Hallucination Guard
HALLUCINATION_CONFIDENCE_THRESHOLD=0.70
HALLUCINATION_ROLLBACK_ENABLED=true

# Document Generation
DOCS_DIR=./generated_docs
DOCS_BASE_URL=http://localhost:8003/api/documents

# SQL Server (for project name lookup)
SQL_SERVER_HOST=your-sql-host
SQL_SERVER_PORT=1433
SQL_DATABASE=your-database
SQL_USERNAME=your-username
SQL_PASSWORD=your-password

# S3 Storage (optional)
STORAGE_BACKEND=local
S3_BUCKET_NAME=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_AGENT_PREFIX=doc-generator

# API Migration (v4) — byTradeAndSet endpoint
USE_NEW_API=true
S3_PDF_URL_PATTERN=https://{bucket}.s3.amazonaws.com/{path}/{name}.pdf
SOURCE_REF_ENABLED=true
